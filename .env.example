# Database
DATABASE_URL=mysql://user:password@host:3306/database

# Auth
JWT_SECRET=your-jwt-secret-here

# App
NODE_ENV=development
APP_URL=https://app.maxxianalise.com

# OAuth (opcional)
OAUTH_SERVER_URL=
OWNER_OPEN_ID=

# Email (Resend)
RESEND_API_KEY=re_xxxxxxxxxxxxxxxxxxxx

# Pagamentos - Asaas
ASAAS_API_KEY=

# Pagamentos - Stripe (opcional)
STRIPE_SECRET_KEY=your_stripe_secret_key_here
STRIPE_WEBHOOK_SECRET=whsec_xxxxxxxxxxxxxxxxxxxx

# AWS S3 (opcional)
AWS_ACCESS_KEY_ID=
AWS_SECRET_ACCESS_KEY=
AWS_REGION=

# Forge (interno)
BUILT_IN_FORGE_API_URL=
BUILT_IN_FORGE_API_KEY=
API_FULL_TOKEN=
API_FULL_BASE_URL=https://api.apifull.com.br
VITE_APP_ID=

# CSRF Protection (gerar com: node -e "require('crypto').randomBytes(32).toString('hex')" | pbcopy)
CSRF_SECRET=gerar_com_openssl_rand_hex_32

# Sentry (monitoramento de erros - opcional, só ativo em NODE_ENV=production)
SENTRY_DSN=https://xxxxxxxxxxxxxxxxxxxx@oXXXXXX.ingest.sentry.io/XXXXXXX
VITE_SENTRY_DSN=https://xxxxxxxxxxxxxxxxxxxx@oXXXXXX.ingest.sentry.io/XXXXXXX
